# The deterministic test env. Committed (it carries no real secrets): the integration
# setup loads it via dotenv, and the db:test:setup / db:e2e:reset / playwright scripts
# read it through dotenv-cli. The student's real Stripe test key lives only in the
# gitignored .env.test.local (see .env.test.local.example).

# The two test databases (both in the docker-compose `postgres-test` service on 55432).
DATABASE_URL_TEST=postgres://test:test@localhost:55432/saas_int_test
DATABASE_URL_E2E=postgres://test:test@localhost:55432/saas_e2e

# env.ts validates DATABASE_URL/DATABASE_URL_UNPOOLED at import; point them at the
# integration DB so `import { env } from '@/env'` succeeds inside the test process.
DATABASE_URL=postgres://test:test@localhost:55432/saas_int_test
DATABASE_URL_UNPOOLED=postgres://test:test@localhost:55432/saas_int_test
SEED=1

# A fixed test-only webhook secret. The route reads env.STRIPE_WEBHOOK_SECRET and the
# postWebhook helper signs with the SAME value → deterministic verification, no
# `stripe listen` dynamic secret. (Gitleaks-safe: no [0-9a-z] run >=8 after whsec_.)
STRIPE_WEBHOOK_SECRET=whsec_test_fixed_for_tests

# env.ts validates the sk_test_ prefix at import and the Stripe singleton needs a key
# to construct, but the integration tests NEVER call live Stripe — subscriptions.retrieve
# is stubbed via vi.mock('@/lib/billing/stripe'). This placeholder is gitleaks-safe (each
# run after sk_test_ is <10 alphanumerics). The Playwright Checkout test needs a real
# test-mode key — the student supplies it in .env.test.local, which overrides this.
STRIPE_SECRET_KEY=sk_test_EXAMPLE_NOT_REAL
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/inspector

# Resend is intercepted by MSW in the integration tests, so this is never a real key.
RESEND_API_KEY=fake_intercepted_by_msw
EMAIL_FROM=Test <test@example.test>
EMAIL_REPLY_TO=reply@example.test

# Test-safe literals for the remaining 065 env (validated at import).
# Low-entropy test literals (repeated words) — long enough to satisfy validation but
# below gitleaks' generic-api-key entropy threshold, so the committed file passes the
# pre-commit hook. The integration/e2e paths never use these values cryptographically.
BETTER_AUTH_SECRET=test-test-test-test-test-test-test
BETTER_AUTH_URL=http://localhost:3001
INVITATION_SIGNING_SECRET=test-test-test-test-test
APP_URL=http://localhost:3001

NEXT_PUBLIC_APP_NAME=Test SaaS
NEXT_PUBLIC_APP_URL=http://localhost:3001
