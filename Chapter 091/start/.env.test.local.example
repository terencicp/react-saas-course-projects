# Copy this to `.env.test.local` (gitignored) and fill in your own values. It overrides
# `.env.test` for the Playwright Checkout test, which creates a REAL test-mode Checkout
# session — that needs a real Stripe test-mode secret key. The integration tests do not
# need it (subscriptions.retrieve is stubbed), so .env.test's placeholder is enough there.

# Your Stripe TEST-MODE secret key (Dashboard → Developers → API keys, test mode).
# Never a live key. Stays only in .env.test.local, never committed.
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Any password — auth.setup.ts signs the seeded admin (admin@e2e.test) in with it, and
# seed-e2e.ts hashes the same value into the seeded credential account.
E2E_ADMIN_PASSWORD=choose-a-password
