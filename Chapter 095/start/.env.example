# Copy this file to .env (and .env.local for `next dev`) and adjust for your setup.
# The migrate/seed scripts load .env via dotenv-cli; next build reads the
# environment directly. Locally both DB URLs point at the same Docker Postgres;
# the pooled/unpooled split exists so Unit 20 can plug Neon in without renaming.
#
# This is the Chapter 095 SEEDED AUDIT TARGET (082 lineage, 082's findings pre-fixed,
# eight NEW observability/performance defects seeded). It boots, builds, and renders
# with every planted defect in place — no third party is reached at build/render time;
# the dummy values below pass env validation without a round-trip.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
DATABASE_URL_UNPOOLED=postgres://postgres:postgres@localhost:5432/app
SEED=1

# Better Auth. BETTER_AUTH_SECRET signs cookies/tokens — generate a fresh one
# with `openssl rand -base64 32` (32+ bytes). BETTER_AUTH_URL is the app's origin.
BETTER_AUTH_SECRET=dev-only-better-auth-secret-change-me-32+
BETTER_AUTH_URL=http://localhost:3000

# The server-side Resend key (lib/email.ts). Server-only — never NEXT_PUBLIC_*.
RESEND_API_KEY=re_dev_placeholder

# The verified sender identity. EMAIL_FROM is a full "Name <addr>" header; the
# address must live on a domain you verified in Resend (SPF/DKIM/DMARC passing).
EMAIL_FROM='Acme <verify@send.acme.example>'
EMAIL_REPLY_TO=support@acme.example

# Signs the invitation accept URL (HMAC over `id.token`). Distinct from
# BETTER_AUTH_SECRET; 32 bytes base64 — `openssl rand -base64 32`.
INVITATION_SIGNING_SECRET=dev-only-invitation-signing-secret-change-me

# Public app identity. NEXT_PUBLIC_APP_URL is the base host for the signed
# invitation accept URL.
NEXT_PUBLIC_APP_NAME=Acme
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (finding 4). The project key is genuinely public; the consent gate, not the
# key, is the seeded defect (src/app/_components/providers.tsx).
NEXT_PUBLIC_POSTHOG_KEY=phc_dev_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash Redis (REST). Server-only; read once by Redis.fromEnv() in src/lib/redis.ts.
# Dummy values pass env validation — no live Redis is reached in the pipeline.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=dev_upstash_token_placeholder

# Stripe (065 carry). Test-mode keys validated at boot. No Stripe CLI in the pipeline.
STRIPE_SECRET_KEY=sk_test_dummy_value
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings

# Trigger.dev v4. Dummy `tr_dev_…`/`proj_…` values pass validation with no round-trip
# — no worker, no cloud project at build/render time. APP_URL is the app origin.
TRIGGER_SECRET_KEY=tr_dev_placeholder
TRIGGER_PROJECT_REF=proj_placeholder
APP_URL=http://localhost:3000

# Sentry (finding 1, wired by slice S3). Absent from the seeded src/env.ts — the
# wiring slice adds the SENTRY_* partitions. Dummy values pass validation with no
# round-trip; the source-map upload is gated on SENTRY_AUTH_TOKEN at build only.
#   SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#   SENTRY_ORG=acme
#   SENTRY_PROJECT=audit-target
#   SENTRY_AUTH_TOKEN=
