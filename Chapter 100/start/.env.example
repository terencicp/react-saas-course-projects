# Copy to .env (cp .env.example .env) and fill in real values. The env validator
# (src/env.ts) fails the build on a missing/invalid var — that failure is the
# launch-checklist artifact lesson 2 demonstrates in the Vercel build log.

# Local Docker Postgres (docker compose up -d). Pooled + unpooled are identical
# locally; the split carries forward to Neon where migrations want the direct one.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
DATABASE_URL_UNPOOLED=postgres://postgres:postgres@localhost:5432/app

# Better Auth.
BETTER_AUTH_SECRET=dev-only-better-auth-secret-please-rotate
BETTER_AUTH_URL=http://localhost:3000

# Validated-not-used: the launch checklist requires the key, but this project
# sends no email.
RESEND_API_KEY=re_dev_placeholder

# Launch-checklist values (not packages — the deployment is by-hand).
SENTRY_DSN=https://dev@example.ingest.sentry.io/0
APP_URL=http://localhost:3000

# Client-exposed.
NEXT_PUBLIC_APP_NAME=Invoices
NEXT_PUBLIC_APP_URL=http://localhost:3000
